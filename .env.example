# ================================================
# DashInsight - Environment Variables untuk Vercel
# ================================================
# Copy nilai-nilai ini ke Vercel Dashboard > Project Settings > Environment Variables

# === DATABASE (Neon PostgreSQL) ===
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# === JWT Authentication ===
JWT_SECRET="ganti-dengan-secret-yang-kuat-dan-random"
JWT_EXPIRES_IN="7d"

# === Security ===
BCRYPT_ROUNDS=12

# === Server ===
NODE_ENV="production"

# === CORS (isi dengan URL Vercel kamu) ===
# Setelah deploy, ganti dengan URL production misal: https://umkm-insight.vercel.app
# Atau pakai * untuk allow semua origin (tidak disarankan untuk production)
CORS_ORIGIN="https://your-project.vercel.app"

# === Frontend (di Vercel, API sudah satu domain jadi cukup /api) ===
VITE_API_URL="/api"
