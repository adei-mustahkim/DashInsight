{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist-api",
    "baseUrl": "."
  },
  "include": ["./**/*.ts", "../server/src/**/*.ts"],
  "exclude": ["node_modules", "../node_modules", "../server/node_modules"]
}
