{
  "name": "dashinsight",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "DashInsight - Cloud-Controlled, Local-First Analytics Platform. Upload data, lihat insight, ambil keputusan.",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "tsc -b && vite build",
    "build:server": "cd server && npm install --include=dev && npx prisma generate && npm run build",
    "vercel-build": "npm run build:server && npm run build",
    "build:template": "node scripts/build-template-workbook.mjs",
    "check": "npm run build:template && npm run lint && npm run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.21"
  }
}
